<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#090b10">

    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:keepScreenOn="true"
        app:resize_mode="fit"
        app:show_timeout="1800"
        app:use_controller="false" />

    <FrameLayout
        android:id="@+id/controls_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:id="@+id/top_chrome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="24dp"
            android:background="#7f111721"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/player_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Native stream"
                android:textColor="#fcf8ef"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/player_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Preparing native player"
                android:textColor="#d4dee6"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/center_transport_overlay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="#7f111721"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="14dp">

            <Button
                android:id="@+id/seek_back_button"
                android:layout_width="92dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="-10s"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/play_pause_button"
                android:layout_width="92dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="Pause"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/seek_forward_button"
                android:layout_width="92dp"
                android:layout_height="wrap_content"
                android:text="+10s"
                android:textAllCaps="false" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/bottom_chrome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="24dp"
            android:background="#7f111721"
            android:orientation="vertical"
            android:padding="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/player_position"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textColor="#fcf8ef"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/player_buffer"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Buffer 0%"
                    android:textColor="#d4dee6"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/player_duration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textColor="#fcf8ef"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <androidx.media3.ui.DefaultTimeBar
                android:id="@+id/player_progress_bar"
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:layout_marginTop="10dp"
                app:ad_marker_color="#66ffffff"
                app:bar_height="4dp"
                app:buffered_color="#80a7c4"
                app:played_ad_marker_color="#fff3dc"
                app:played_color="#fff3dc"
                app:scrubber_color="#fff3dc"
                app:touch_target_height="32dp"
                app:unplayed_color="#33576f86" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/pip_button"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:text="PiP"
                    android:textAllCaps="false" />

                <Button
                    android:id="@+id/close_button"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Close"
                    android:textAllCaps="false" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

</FrameLayout>